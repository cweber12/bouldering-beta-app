# Environment variables
# Copy this file to .env.local and fill in values.
# .env.local is gitignored — never commit secrets.

# Minimum inlier count for a homography to be considered valid.
# Tune this based on scene complexity. Recommended starting value: 12.
NEXT_PUBLIC_HOMOGRAPHY_MIN_INLIERS=12

# Maximum number of ORB keypoints to detect per frame.
NEXT_PUBLIC_ORB_MAX_KEYPOINTS=500

# TF.js pose model: "movenet_lightning" | "movenet_thunder" | "blazepose"
NEXT_PUBLIC_POSE_MODEL=movenet_lightning

# ---- AWS / S3 (server-side only — never prefix with NEXT_PUBLIC_) -----------
# The AWS region where your S3 bucket lives.
AWS_REGION=us-east-1

# IAM credentials with s3:GetObject, s3:PutObject, s3:DeleteObject,
# and s3:ListBucket permissions on the bucket below.
AWS_ACCESS_KEY_ID=YOUR_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY=YOUR_SECRET_ACCESS_KEY

# Name of the S3 bucket where attempts are stored.
S3_BUCKET_NAME=your-route-renderer-bucket

# Top-level prefix used inside the bucket. Default: RouteData
# Objects are stored at: S3_KEY_PREFIX/<userId>/<state>/<area>/<route>/<run-id>.json
S3_KEY_PREFIX=RouteData

# ---- Supabase Auth (client-side — NEXT_PUBLIC_ prefix is intentional) ------
# Your Supabase project URL and publishable anon key.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
