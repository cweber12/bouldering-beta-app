# Environment variables
# Copy this file to .env.local and fill in values.
# .env.local is gitignored — never commit secrets.

# Minimum inlier count for a homography to be considered valid.
# Tune this based on scene complexity. Recommended starting value: 12.
NEXT_PUBLIC_HOMOGRAPHY_MIN_INLIERS=12

# Maximum number of ORB keypoints to detect per frame.
NEXT_PUBLIC_ORB_MAX_KEYPOINTS=500

# MediaPipe Pose Landmarker variant: "lite" | "full" | "heavy"
NEXT_PUBLIC_POSE_MODEL=lite

# ---- Firebase (client-side — safe to expose, NEXT_PUBLIC_ prefix required) --
NEXT_PUBLIC_FIREBASE_API_KEY=your-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
NEXT_PUBLIC_FIREBASE_APP_ID=your-app-id

# ---- Firebase Admin (server-side only — never prefix with NEXT_PUBLIC_) -----
# Download from Firebase console: Project Settings → Service Accounts → Generate new private key
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
# Paste the private key exactly as-is; newlines will be encoded as \n in the file.
FIREBASE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n"

# ---- AWS / S3 (server-side only — never prefix with NEXT_PUBLIC_) -----------
# The AWS region where your S3 bucket lives.
AWS_REGION=us-east-1

# IAM credentials with s3:GetObject, s3:PutObject, s3:DeleteObject,
# and s3:ListBucket permissions on the bucket below.
AWS_ACCESS_KEY_ID=YOUR_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY=YOUR_SECRET_ACCESS_KEY

# Name of the S3 bucket where attempts and profile data are stored.
S3_BUCKET_NAME=your-route-renderer-bucket

# Top-level prefix used inside the bucket. Default: RouteData
# Objects are stored at: S3_KEY_PREFIX/<userId>/<state>/<area>/<route>/<run-id>.json
# Profile data is stored at: ProfileData/<userId>/...
S3_KEY_PREFIX=RouteData
