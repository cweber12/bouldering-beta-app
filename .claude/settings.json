{
  "permissions": {
    "allow": [
      "Bash(npx tsc --noEmit)",
      "Bash(npx vitest run*)",
      "Bash(npx vitest*)",
      "Bash(npx eslint .)",
      "Bash(npm run format:check)",
      "Bash(npm run format)",
      "Bash(npm run setup:opencv)",
      "Bash(npm run dev)",
      "Bash(npm run build)",
      "Bash(npm ci)",
      "Bash(git status)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git add .)",
      "Bash(git commit*)",
      "Bash(git push)",
      "Bash(npx next build)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "npx tsc --noEmit 2>&1 | head -20"
          }
        ]
      }
    ]
  }
}
